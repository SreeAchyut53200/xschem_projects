C {code_shown.sym} -1000 -340 0 0 {name=bro only_toplevel=false spice_ignore=true value=
"
.param VSS=0 VCC=1.8 Vcm=0.39 Vdif=0.093 time_period=30ns prds=16 rise=10ps fall=10ps

VCC VCC 0 DC 1.8
VSS VSS 0 DC 0

V_CLK CLK 0 PULSE(\{VCC\} \{VSS\} 0ns \{rise\} \{fall\} \{time_period/2\} \{time_period\} \{prds\})
V_CLK_bar CLK_bar 0 PULSE(\{VSS\} \{VCC\} 0ns \{rise\} \{fall\} \{time_period/2\} \{time_period\} \{prds\})

V_IN1 IN1 0 PULSE(\{Vdif\} \{Vcm\} 0 100ps 100ps \{time_period\} \{time_period*2\} \{prds/2\})
V_IN2 IN2 0 PULSE(\{Vcm\} \{Vdif\} 0 100ps 100ps \{time_period\} \{time_period*2\} \{prds/2\})

V_EN EN 0 PULSE(\{VCC\} \{VSS\} 0ns \{rise\} \{fall\} \{time_period*prds/6\} \{time_period*prds/2\} prds)
V_EN_bar EN_bar 0 PULSE(\{VSS\} \{VCC\} 0ns \{rise\} \{fall\} \{time_period*prds/8\} \{time_period*prds/4\} prds)

.tran 0.01ns \{time_period*prds\}
.save all

.control
run
plot v(IN1) v(IN2) v(x1.OUT+)+2.2 v(x1.OUT-)+2.2 Q-2.2 Q_bar-2.2 CLK+4.2 en+6.2
  foreach vdif 0.093 0.092 0.089 0.087 0.086 0.085 0.083 0.081
    alterparam Vdif = $vdif
    reset
    run
    plot v(IN1) v(IN2) v(x1.OUT+)+2.2 v(x1.OUT-)+2.2 Q-2.2 Q_bar-2.2 CLK+4.2 en+6.2
  end
.endc
"}
