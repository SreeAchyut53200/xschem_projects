C {code.sym} -1170 -870 0 0 {name="Vcm 0.6" only_toplevel=false spice_ignore=true value=
"
.param VSS=0 VCC=1.8 Vcm=0.37 Vdif=0.92 time_period=15ns prds=10 rise=10ps fall=10ps

VCC VCC 0 DC 1.8
VSS VSS 0 DC 0
V_EN EN 0 DC 1.8
V_EN_bar EN_bar 0 DC 0
V_CLK CLK 0 PULSE(\{VCC\} \{VSS\} 0ns \{rise\} \{fall\} \{(time_period)/2\} \{time_period\} \{prds\})
V_CLK_bar CLK_bar 0 PULSE(\{VSS\} \{VCC\} 0ns \{rise\} \{fall\} \{(time_period)/2\} \{time_period\} \{prds\})

V_IN1 IN1 0 PULSE(\{Vcm+Vdif/2\} \{Vcm-Vdif/2\} 0 \{rise\} \{fall\} \{time_period\} \{time_period*2\} \{prds/2\})
V_IN2 IN2 0 PULSE(\{Vcm-Vdif/2\} \{Vcm+Vdif/2\} 0 \{rise\} \{fall\} \{time_period\} \{time_period*2\} \{prds/2\})

.tran 0.01ns \{time_period*prds\}
.save all

.control
run
plot IN1 IN2 v(x1.OUT+)+2.2 v(x1.OUT-)+2.2 Q-2.2 Q_bar-2.2 CLK+4.2 en+6.2
* 
*  foreach vdif 0.2 0.25 0.1 0.15 0.07
*    alterparam Vdif = $vdif
*    reset
*    run
*    plot v(IN+)+2.2 v(IN-)+2.2 v(OUT+) v(OUT-) Q-2.2 Q_bar-2.2 CLK+4.4 CLK_bar+4.4 
*  end
.endc
"}
